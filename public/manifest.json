{
  "manifest_version": 3,
  "name": "Judol Detector",
  "version": "1.0",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["keywords.txt"],
      "matches": ["<all_urls>"]
    }
  ]
}
